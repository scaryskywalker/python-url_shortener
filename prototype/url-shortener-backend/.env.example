APP_NAME=Merchant URL Shortener
APP_ENV=development
BASE_URL=http://localhost:8000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=url_shortener_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Optional on Render: use REDIS_URL instead of REDIS_HOST/REDIS_PORT/REDIS_DB.
# REDIS_URL=redis://red-example:6379

API_RATE_LIMIT_PER_MINUTE=100
REDIS_SHORT_URL_CACHE_SECONDS=3600
